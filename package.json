{
  "name": "ai-project-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.mjs\" \"vite --host 127.0.0.1\"",
    "server": "node server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "report:discord": "node scripts/send-discord-report.mjs",
    "report:discord:dry": "node scripts/send-discord-report.mjs --dry-run",
    "report:discord:snapshot": "node scripts/send-discord-report.mjs --from-snapshots --no-attach",
    "report:discord:snapshot:dry": "node scripts/send-discord-report.mjs --from-snapshots --no-attach --dry-run",
    "orchestration:install": "node scripts/install-orchestration.mjs",
    "orchestration:dashboard": "node scripts/build-orchestration-dashboard.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.0"
  }
}
